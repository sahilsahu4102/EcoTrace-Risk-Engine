# Scrapingdog API Key (for CSR page scraping)
# Get yours at: https://scrapingdog.com
SCRAPINGDOG_API_KEY=your_scrapingdog_api_key_here

# Global Forest Watch API Key (for tree cover loss data)
# Register free at: https://www.globalforestwatch.org/my-gfw/
GFW_API_KEY=your_gfw_api_key_here

# OpenRouter API Key (for LLM context extraction)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
